{
  "entities": {
    "Character": {
      "title": "Character",
      "description": "A Dark Core character sheet",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "level": { "type": "number" },
        "xp": { "type": "number" },
        "class": { "type": "string" },
        "ancestry": { "type": "string" },
        "attributes": { "type": "object" },
        "advDis": { "type": "object" },
        "armor": { "type": "object" },
        "shield": { "type": "object" },
        "hp": { "type": "object" },
        "inventory": { "type": "array" },
        "stress": { "type": "number" },
        "campaignId": { "type": "string", "description": "ID of the campaign this character belongs to, null if none" }
      },
      "required": ["id", "userId", "name", "level", "class", "ancestry"]
    },
    "User": {
      "title": "User",
      "description": "User identifier mapping",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "6-digit ID" },
        "nickname": { "type": "string", "description": "Display name of the user" },
        "createdAt": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["Mestre", "Jogador"] }
      },
      "required": ["id"]
    },
    "Campaign": {
      "title": "Campaign",
      "description": "A GM lead RPG campaign",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "gmId": { "type": "string" },
        "playerIds": { "type": "array" },
        "characterIds": { "type": "array" },
        "createdAt": { "type": "string" }
      }
    },
    "Roll": {
      "title": "Roll",
      "description": "A d20 roll log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "characterId": { "type": "string" },
        "characterName": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "value": { "type": "number" },
        "modifier": { "type": "number" },
        "label": { "type": "string" },
        "timestamp": { "type": "number" },
        "advantageMode": { "type": "string" }
      }
    },
    "Spell": {
      "title": "Spell",
      "description": "A Shadowdark RPG spell",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "tier": { "type": "number" },
        "range": { "type": "string" },
        "duration": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "name", "tier", "range", "duration", "type", "description"]
    },
    "CampaignNote": {
      "title": "CampaignNote",
      "description": "A card note created in a campaign",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "campaignId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "folderId": { "type": "string" },
        "category": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorRole": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "campaignId", "title", "content"]
    },
    "CampaignFolder": {
      "title": "CampaignFolder",
      "description": "A folder to store notes in a campaign",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "campaignId": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "campaignId", "name"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of registered 6-digit user IDs"
    },
    "characters/{characterId}": {
      "schema": "Character",
      "description": "All character sheets across all users"
    },
    "campaigns/{campaignId}": {
      "schema": "Campaign",
      "description": "Campaign data"
    },
    "rolls/{rollId}": {
      "schema": "Roll",
      "description": "Roll history"
    },
    "spells/{spellId}": {
      "schema": "Spell",
      "description": "Global list of spells for the system"
    },
    "campaign_notes/{noteId}": {
      "schema": "CampaignNote",
      "description": "Notes made by players or GM in campaigns"
    },
    "campaign_folders/{folderId}": {
      "schema": "CampaignFolder",
      "description": "Folders/categories to organize notes"
    }
  }
}
